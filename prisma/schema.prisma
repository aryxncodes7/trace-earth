datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String        @default("")
  name           String?
  image          String?
  city           String?
  country        String?
  isAnonymous    Boolean       @default(false)
  targetKgPerDay Float         @default(13.7)
  createdAt      DateTime      @default(now())
  logs           ActivityLog[]
}

model ActivityLog {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime  @default(now())
  transportKg      Float
  energyKg         Float
  dietKg           Float
  shoppingKg       Float
  totalKg          Float
  aiTipCache       String?
  aiTipGeneratedAt DateTime?
  createdAt        DateTime  @default(now())
}
